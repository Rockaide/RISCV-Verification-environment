{
  "$schema": "/opt/riscv/share/sail-riscv/sail_riscv_config_schema.json",
  "base": {
    "xlen": 32,
    "E": false,
    "writable_misa": false,
    // cv32e40x has no menvcfg register (M-mode only, no S/U-mode).
    // SCHEMA-REQUIRED: no RTL counterpart; value has no effect on DUT comparison.
    "writable_fiom": true,
    "writable_hpm_counters": {
      "len": 32,
      // NUM_MHPMCOUNTERS=1 by default. Only mhpmcounter3 is active.
      "value": "0x00000008"
    },
    // cv32e40x has no S-mode so scounteren does not exist.
    // SCHEMA-REQUIRED: no RTL counterpart.
    "scounteren_writable_bits": {
      "len": 32,
      "value": "0x0"
    },
    "xtval_nonzero": {
      // mtval is hardwired to 0 in cv32e40x.
      "illegal_instruction": false,
      "software_breakpoint": false,
      "hardware_breakpoint": false,
      "load_address_misaligned": false,
      "load_access_fault": false,
      "load_page_fault": false,
      "samo_address_misaligned": false,
      "samo_access_fault": false,
      "samo_page_fault": false,
      "fetch_address_misaligned": false,
      "fetch_access_fault": false,
      "fetch_page_fault": false,
      "software_check": false,
      "reserved_exceptions": false
    },
    "reserved_behavior": {
      // SCHEMA-REQUIRED: cv32e40x has no Zacas extension.
      // Value has no effect on DUT comparison.
      "amocas_odd_register": "AMOCAS_Illegal",
      // SCHEMA-REQUIRED: F not implemented internally.
      "fcsr_rm": "Fcsr_RM_Illegal",
      // SCHEMA-REQUIRED: cv32e40x has no PMP.
      "pmpcfg_write_only": "PMP_ClearPermissions",
      // SCHEMA-REQUIRED: cv32e40x has no Zicbom.
      "xenvcfg_cbie": "Xenvcfg_ClearPermissions",
      // mtvec MODE supports 0 (direct) and 1 (vectored); writes of mode >= 2 are ignored.
      "xtvec_mode": "Xtvec_Ignore",
      // SCHEMA-REQUIRED: cv32e40x has no Zdinx.
      "rv32zdinx_odd_register": "Zdinx_Illegal"
    }
  },
  "memory": {
    // cv32e40x has no PMP
    "pmp": {
      "grain": 0,
      "count": 0,
      "usable_count": 0,
      "tor_supported": true,
      "na4_supported": true,
      "napot_supported": true
    },
    "misaligned": {
      "exceptions": {
        // Regular loads/stores: handled in hardware for main memory; access fault in I/O.
        "load_store": { "None": null },
        // SCHEMA-REQUIRED: no V extension.
        "vector": { "None": null },
        // LR.W/SC.W with non-naturally aligned address raises address misaligned exception
        // (User Manual, Exceptions and Interrupts: exception codes 4/6).
        // Access fault takes priority if the region has no atomic support (PMA).
        "lrsc": "AlignmentException",
        // Misaligned AMO raises store/AMO address misaligned (code 6).
        "amo": "AlignmentException"
      },
      "allowed_within_exp": 0,
      "byte_by_byte": false,
      "order_decreasing": false
    },
    "translation": {
      "dirty_update": false
    },
    "dtb_address": {
      "len": 64,
      "value": "0x1000"
    },
    "regions": [
      // Main memory: code and data. Tests link from 0x80 (see link.ld).
      // Atomics supported here (A_EXT=A; external adapter handles read-modify-write).
      {
        "base": {
          "len": 64,
          "value": "0x0"
        },
        "size": {
          "len": 64,
          "value": "0x2000000"
        },
        "attributes": {
          "mem_type": "MainMemory",
          "cacheable": true,
          "coherent": true,
          "executable": true,
          "readable": true,
          "writable": true,
          "read_idempotent": true,
          "write_idempotent": true,
          "misaligned_exceptions": {
            // Regular loads/stores handled in hardware in main memory.
            "load_store": { "None": null },
            "vector": { "None": null },
            // Misaligned AMO in main memory raises address misaligned (before PMA check).
            "amo": "AlignmentException"
          },
          // A_EXT=A: full AMO (amoswap/amoadd/amoand/amoor/amoxor/amomax/amomin)
          "atomic_support": "AMOArithmetic",
          // LR/SC reservation sets managed externally; non-eventual (conservative).
          "reservability": "RsrvNonEventual",
          "supports_cbo_zero": false,
          "supports_pte_read": false,
          "supports_pte_write": false
        },
        "include_in_device_tree": true
      },
      // IO memory: covers CLINT at 0x2000000, Sail interrupt generator at 0xC000000.
      // Atomics NOT supported in I/O regions (PMA access fault for LR/SC/AMO).
      {
        "base": {
          "len": 64,
          "value": "0x2000000"
        },
        "size": {
          "len": 64,
          "value": "0xFE000000"
        },
        "attributes": {
          "mem_type": "IOMemory",
          "cacheable": false,
          "coherent": true,
          "executable": false,
          "readable": true,
          "writable": true,
          "read_idempotent": false,
          "write_idempotent": false,
          "misaligned_exceptions": {
            // Misaligned regular load/store in I/O raises access fault (codes 5/7).
            "load_store": { "AccessFault": null },
            "vector": { "None": null },
            // LR/SC or AMO in I/O region raises access fault (PMA atomic attribute not set).
            "amo": "AccessFault"
          },
          // No atomic support in I/O regions.
          "atomic_support": "AMONone",
          "reservability": "RsrvNone",
          "supports_cbo_zero": false,
          "supports_pte_read": false,
          "supports_pte_write": false
        },
        "include_in_device_tree": false
      }
    ]
  },
  "platform": {
    // OpenHW Group JEDEC: bank=0xC, offset=0x2, mvendorid=0x602=1538
    "vendorid": 1538,
    // marchid=0x14 (decimal 20)
    "archid": 20,
    "impid": 0,
    "hartid": 0,
    "cache_block_size_exp": 6,
    "reservation": {
      // A_EXT=A; reservation set managed externally by memory subsystem.
      "reservation_set_size_exp": 3,
      "require_exact_reservation_addr": false
    },
    "clint": {
      "base": 33554432,
      "size": 786432
    },
    "simple_interrupt_generator": {
      "base": 201326592
    },
    "clock_frequency": 1000000000,
    "instructions_per_tick": 2,
    "wfi_is_nop": false,
    "max_time_to_wait": 10
  },
  "extensions": {
