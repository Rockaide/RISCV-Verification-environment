{
  "$schema": "/opt/riscv/share/sail-riscv/sail_riscv_config_schema.json",
  "base": {
    "xlen": 32,
    "E": false,
    "writable_misa": false,
    // cv32e40x has no menvcfg register (M-mode only, no S/U-mode).
    // SCHEMA-REQUIRED: no RTL counterpart; value has no effect on DUT comparison.
    "writable_fiom": true,
    "writable_hpm_counters": {
      "len": 32,
      // NUM_MHPMCOUNTERS=1 by default. Only mhpmcounter3 is active.
      // Bit 3 set = mhpmcounter3/mhpmevent3 writable; counters 4-31 read-only zero.
      "value": "0x00000008"
    },
    // cv32e40x has no S-mode so scounteren does not exist.
    // SCHEMA-REQUIRED: no RTL counterpart.
    "scounteren_writable_bits": {
      "len": 32,
      "value": "0x0"
    },
    // These settings control whether the specified exceptions
    // cause information to be written into the appropriate
    // `xtval` registers.
    "xtval_nonzero": {
      // mtval is hardwired to 0 in cv32e40x (WARL 0x0 per CSR doc).
      "illegal_instruction": false,
      "software_breakpoint": false,
      "hardware_breakpoint": false,
      "load_address_misaligned": false,
      "load_access_fault": false,
      "load_page_fault": false,
      "samo_address_misaligned": false,
      "samo_access_fault": false,
      "samo_page_fault": false,
      "fetch_address_misaligned": false,
      "fetch_access_fault": false,
      "fetch_page_fault": false,
      "software_check": false,
      "reserved_exceptions": false
    },
    "reserved_behavior": {
      // SCHEMA-REQUIRED: cv32e40x has no Zacas extension; AMO instructions decode as
      // illegal (A_EXT=A_NONE). Value has no effect on DUT comparison.
      "amocas_odd_register": "AMOCAS_Illegal",
      // SCHEMA-REQUIRED: F extension not implemented internally.
      // Value has no effect on DUT comparison.
      "fcsr_rm": "Fcsr_RM_Illegal",
      // SCHEMA-REQUIRED: cv32e40x has no PMP.
      // Value has no effect on DUT comparison.
      "pmpcfg_write_only": "PMP_ClearPermissions",
      // SCHEMA-REQUIRED: cv32e40x has no Zicbom. Value has no effect on DUT comparison.
      "xenvcfg_cbie": "Xenvcfg_ClearPermissions",
      // mtvec[6:2] bits hardwired to 0; mtvec[1:0] MODE supports 0 (direct) and 1 (vectored).
      // Writes of mode >= 2 are ignored and old mode is retained.
      "xtvec_mode": "Xtvec_Ignore",
      // SCHEMA-REQUIRED: cv32e40x has no Zdinx. Value has no effect on DUT comparison.
      "rv32zdinx_odd_register": "Zdinx_Illegal"
    }
  },
  "memory": {
    // cv32e40x has no PMP (no pmpcfg/pmpaddr CSRs)
    "pmp": {
      "grain": 0,
      "count": 0,
      "usable_count": 0,
      // SCHEMA-REQUIRED: PMP type fields below are irrelevant with count=0.
      "tor_supported": true,
      "na4_supported": true,
      "napot_supported": true
    },
    "misaligned": {
      "exceptions": {
        // cv32e40x LSU handles misaligned loads/stores in hardware for Main memory regions
        // (two bus transactions, lowest address first). No misaligned exception raised.
        // In I/O regions, misaligned access causes an access fault (code 5 or 7).
        "load_store": { "None": null },
        // SCHEMA-REQUIRED: cv32e40x has no V extension.
        "vector": { "None": null },
        // SCHEMA-REQUIRED: A_EXT=A_NONE by default; LR/SC opcodes decode as illegal.
        "lrsc": "AccessFault",
        // SCHEMA-REQUIRED: A_EXT=A_NONE by default; AMO opcodes decode as illegal.
        "amo": "AccessFault"
      },
      "allowed_within_exp": 0,
      "byte_by_byte": false,
      "order_decreasing": false
    },
    "translation": {
      // cv32e40x has no MMU (M-mode only, no virtual memory).
      "dirty_update": false
    },
    "dtb_address": {
      "len": 64,
      "value": "0x1000"
    },
    // cv32e40x with PMA_NUM_REGIONS=0 (default) treats all memory as main memory.
    // Memory regions below are required by the Sail config schema.
    "regions": [
      // Main memory: code and data. Tests link from 0x80 (see link.ld).
      {
        "base": {
          "len": 64,
          "value": "0x0"
        },
        "size": {
          "len": 64,
          "value": "0x2000000"
        },
        "attributes": {
          "mem_type": "MainMemory",
          "cacheable": true,
          "coherent": true,
          "executable": true,
          "readable": true,
          "writable": true,
          "read_idempotent": true,
          "write_idempotent": true,
          "misaligned_exceptions": {
            // cv32e40x handles misaligned loads/stores in hardware in main memory.
            "load_store": { "None": null },
            // SCHEMA-REQUIRED: no V extension.
            "vector": { "None": null },
            // SCHEMA-REQUIRED: no A extension.
            "amo": "AccessFault"
          },
          "atomic_support": "AMONone",
          "reservability": "RsrvNone",
          "supports_cbo_zero": false,
          "supports_pte_read": false,
          "supports_pte_write": false
        },
        "include_in_device_tree": true
      },
      // IO memory: covers CLINT at 0x2000000, Sail interrupt generator at 0xC000000,
      // and the full remaining 32-bit address space.
      {
        "base": {
          "len": 64,
          "value": "0x2000000"
        },
        "size": {
          "len": 64,
          "value": "0xFE000000"
        },
        "attributes": {
          "mem_type": "IOMemory",
          "cacheable": false,
          "coherent": true,
          "executable": false,
          "readable": true,
          "writable": true,
          "read_idempotent": false,
          "write_idempotent": false,
          "misaligned_exceptions": {
            // cv32e40x raises access fault for misaligned accesses in I/O regions.
            "load_store": { "AccessFault": null },
            // SCHEMA-REQUIRED: no V extension.
            "vector": { "None": null },
            // SCHEMA-REQUIRED: no A extension.
            "amo": "AccessFault"
          },
          "atomic_support": "AMONone",
          "reservability": "RsrvNone",
          "supports_cbo_zero": false,
          "supports_pte_read": false,
          "supports_pte_write": false
        },
        "include_in_device_tree": false
      }
    ]
  },
  "platform": {
    // OpenHW Group JEDEC: bank=0xC, offset=0x2 → mvendorid=0x602=1538
    "vendorid": 1538,
    // marchid=0x14 (decimal 20) per User Manual, Control and Status Registers
    "archid": 20,
    // mimpid=0x0 with mimpid_patch_i=0 (default baseline configuration)
    "impid": 0,
    "hartid": 0,
    // SCHEMA-REQUIRED: cv32e40x has no cache (no Zicbom/Zicboz). Value has no effect on DUT comparison.
    "cache_block_size_exp": 6,
    "reservation": {
      // SCHEMA-REQUIRED: A_EXT=A_NONE; LR/SC is never executed.
      "reservation_set_size_exp": 3,
      "require_exact_reservation_addr": false
    },
    "clint": {
      // This must be in a suitable memory region.
      "base": 33554432,
      "size": 786432
    },
    "simple_interrupt_generator": {
      "base": 201326592
    },
    "clock_frequency": 1000000000,
    "instructions_per_tick": 2,
    // cv32e40x has a sleep unit; WFI causes the core to enter sleep (not a NOP).
    "wfi_is_nop": false,
    "max_time_to_wait": 10
  },
