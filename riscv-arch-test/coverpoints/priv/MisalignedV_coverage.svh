    option.per_instance = 0;
// //////////////////////////////////////////////////////////////////////////////////////////////////////////
// cp_misalignedv_ls_element_misaligned
// //////////////////////////////////////////////////////////////////////////////////////////////////////////
//
// Exercise vector memory accesses whose base address is not naturally aligned
